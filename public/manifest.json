{
  "manifest_version": 3,
  "minimum_chrome_version": "116",
  "name": "GradLedger",
  "version": "0.5.0",
  "description": "Save professors, graduate programs, requirements, and deadlines while browsing.",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "sidePanel",
    "contextMenus",
    "offscreen",
    "tabs"
  ],
  "host_permissions": ["http://*/*", "https://*/*"],
  "optional_host_permissions": ["http://*/*", "https://*/*"],
  "background": {
    "service_worker": "service-worker.js",
    "type": "module"
  },
  "action": {
    "default_title": "Analyze this page"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
