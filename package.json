{
  "name": "gradledger",
  "version": "0.5.1",
  "private": true,
  "type": "module",
  "description": "Local-first Chrome extension for saving structured graduate application records while browsing university pages.",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "tsc --noEmit && vite build && vite build --config vite.content.config.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "preview": "vite preview --host 127.0.0.1"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "vite": "^6.0.7",
    "typescript": "^5.7.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.287",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "vitest": "^2.1.8",
    "playwright": "^1.49.1"
  }
}
